<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BlogCategoryMapper">

    <resultMap type="BlogCategory" id="BlogCategoryResult">
        <id     property="categoryId"    column="category_id"    />
        <result property="categoryName"  column="category_name"  />
        <result property="description"   column="description"    />
        <result property="parentId"      column="parent_id"      />
        <result property="orderNum"      column="order_num"      />
        <result property="status"        column="status"         />
        <result property="createBy"      column="create_by"      />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="articleCount"  column="article_count"  />
    </resultMap>

    <sql id="selectCategoryVo">
        select c.category_id, c.category_name, c.description, c.parent_id, c.order_num,
               c.status, c.create_by, c.create_time, c.update_time,
               (select count(1) from blog_article a where a.category_id = c.category_id) as article_count
        from blog_category c
    </sql>

    <select id="selectCategoryById" parameterType="Long" resultMap="BlogCategoryResult">
        <include refid="selectCategoryVo"/>
        where c.category_id = #{categoryId}
    </select>

    <select id="selectCategoryList" parameterType="BlogCategory" resultMap="BlogCategoryResult">
        <include refid="selectCategoryVo"/>
        <where>
            <if test="categoryName != null and categoryName != ''">
                AND c.category_name like concat('%', #{categoryName}, '%')
            </if>
            <if test="status != null and status != ''">
                AND c.status = #{status}
            </if>
        </where>
        order by c.order_num asc, c.create_time desc
    </select>

    <insert id="insertCategory" parameterType="BlogCategory" useGeneratedKeys="true" keyProperty="categoryId">
        insert into blog_category
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="categoryName != null and categoryName != ''">category_name,</if>
            <if test="description != null">description,</if>
            <if test="parentId != null">parent_id,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="categoryName != null and categoryName != ''">#{categoryName},</if>
            <if test="description != null">#{description},</if>
            <if test="parentId != null">#{parentId},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateCategory" parameterType="BlogCategory">
        update blog_category
        <set>
            <if test="categoryName != null and categoryName != ''">category_name = #{categoryName},</if>
            <if test="description != null">description = #{description},</if>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            update_time = sysdate()
        </set>
        where category_id = #{categoryId}
    </update>

    <delete id="deleteCategoryById" parameterType="Long">
        delete from blog_category where category_id = #{categoryId}
    </delete>

    <delete id="deleteCategoryByIds" parameterType="Long">
        delete from blog_category where category_id in
        <foreach item="categoryId" collection="array" open="(" separator="," close=")">
            #{categoryId}
        </foreach>
    </delete>
</mapper>
